# ─── Économe Environment Variables ─────────────────────────────────────
#
# Copy this file to .env and fill in the values.
#
# SENTRY_DSN — Your Sentry project DSN for crash reporting.
#   Get this from https://sentry.io/settings/projects/<project>/keys/
#   Example: https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@o123456.ingest.sentry.io/1234567
#
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── Future configuration ───────────────────────────────────────────────
# DB_PASSPHRASE  — Passphrase for SQLCipher database encryption.
#                  Currently hardcoded in database_builder.dart; should be
#                  moved to flutter_secure_storage in a future iteration.
