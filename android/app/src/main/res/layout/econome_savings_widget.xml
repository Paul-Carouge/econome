<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="14dp"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/savings_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Objectif épargne"
        android:textSize="10sp"
        android:textColor="#71717A"
        android:textAllCaps="true"
        android:letterSpacing="0.06" />

    <TextView
        android:id="@+id/savings_widget_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="#E4E4E7"
        android:layout_marginTop="2dp"
        android:singleLine="true"
        android:ellipsize="end" />

    <TextView
        android:id="@+id/savings_widget_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#10B981"
        android:layout_marginTop="3dp" />

    <ProgressBar
        android:id="@+id/savings_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginTop="8dp"
        android:progress="0"
        android:max="100"
        android:progressDrawable="@drawable/widget_progress_savings"
        android:progressBackgroundTint="#27272A" />

    <TextView
        android:id="@+id/savings_widget_pct"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text=""
        android:textSize="10sp"
        android:textColor="#A1A1AA"
        android:layout_marginTop="3dp"
        android:gravity="center_vertical" />

</LinearLayout>
