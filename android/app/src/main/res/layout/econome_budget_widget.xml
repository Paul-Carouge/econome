<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="#0F1011">

    <TextView
        android:id="@+id/budget_widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Budget mensuel"
        android:textSize="10sp"
        android:textColor="#71717A"
        android:gravity="start" />

    <TextView
        android:id="@+id/budget_widget_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="—"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#F59E0B"
        android:layout_marginTop="4dp" />

    <ProgressBar
        android:id="@+id/budget_progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="10dp"
        android:layout_marginTop="10dp"
        android:progress="0"
        android:max="100"
        android:progressTint="#F59E0B"
        android:progressBackgroundTint="#27272A" />

    <TextView
        android:id="@+id/budget_widget_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="10sp"
        android:textColor="#A1A1AA"
        android:layout_marginTop="6dp" />

</LinearLayout>
